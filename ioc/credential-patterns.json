{
  "version": "2026.03.03",
  "last_updated": "2026-03-03",
  "api_key_patterns": [
    {"pattern": "sk-[a-zA-Z0-9]{20,}", "description": "OpenAI API key", "severity": "critical"},
    {"pattern": "sk-ant-[a-zA-Z0-9-]{50,}", "description": "Anthropic API key", "severity": "critical"},
    {"pattern": "sk-proj-[a-zA-Z0-9-]{50,}", "description": "OpenAI project key", "severity": "critical"},
    {"pattern": "key-[a-zA-Z0-9]{20,}", "description": "Generic API key", "severity": "high"},
    {"pattern": "ghp_[a-zA-Z0-9]{36}", "description": "GitHub personal access token", "severity": "critical"},
    {"pattern": "gho_[a-zA-Z0-9]{36}", "description": "GitHub OAuth token", "severity": "critical"},
    {"pattern": "github_pat_[a-zA-Z0-9]{22}_[a-zA-Z0-9]{59}", "description": "GitHub fine-grained PAT", "severity": "critical"},
    {"pattern": "xoxb-[0-9]{10,}-[a-zA-Z0-9]{20,}", "description": "Slack bot token", "severity": "high"},
    {"pattern": "xoxp-[0-9]{10,}-[a-zA-Z0-9]{20,}", "description": "Slack user token", "severity": "high"},
    {"pattern": "AKIA[0-9A-Z]{16}", "description": "AWS access key ID", "severity": "critical"},
    {"pattern": "glpat-[a-zA-Z0-9_-]{20}", "description": "GitLab personal access token", "severity": "high"}
  ],
  "env_variable_names": [
    "RESEND_API_KEY",
    "OPENROUTER_API_KEY",
    "ANTHROPIC_API_KEY",
    "OPENAI_API_KEY",
    "SUPABASE_SERVICE_KEY",
    "UPSTASH_REDIS_REST_TOKEN"
  ],
  "sensitive_file_locations": [
    "~/.openclaw/credentials/",
    "~/.openclaw/openclaw.json",
    "~/.clawdbot/.env",
    "~/.openclaw/credentials/openrouter",
    "~/.openclaw/credentials/anthropic",
    "~/.openclaw/credentials/oauth.json"
  ],
  "leak_locations": [
    "Chat output (agent prints env var values)",
    "Git commits (openclaw.json with plaintext keys)",
    "Log files (tool output not redacted)",
    "Session history files (.jsonl)",
    "Memory files (memory/*.md)",
    "Shared workspace files",
    "SKILL.md configuration examples",
    "Error messages with stack traces"
  ]
}
